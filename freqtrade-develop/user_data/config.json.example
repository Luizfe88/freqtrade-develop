{
    "max_open_trades": 3,
    "logging": {
        "logfile": "user_data/logs/freqtrade.log",
        "verbosity": "info"
    },
    "trailing_stop": false,
    "stake_currency": "USDT",
    "stake_amount": 50,
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "USD",
    "timeframe": "1h",
    "informational_pairs": ["BTC/USDT"],
    "dry_run": true,
    "dry_run_wallet": 1000,
    "telegram": {
      "enabled": true,
      "token": "YOUR_TELEGRAM_TOKEN_HERE",
      "chat_id": "YOUR_CHAT_ID_HERE",
      "allow_custom_messages": true,
      "notification_settings": {
        "status":           "on",
        "warning":          "on",
        "startup":          "on",
        "entry":            "on",
        "entry_fill":       "on",
        "entry_cancel":     "on",
        "exit":             "on",
        "exit_fill":        "on",
        "exit_cancel":      "on",
        "protection_trigger": "on",
        "protection_trigger_global": "on",
        "show_candle":      "off",
        "balance":          "on",
        "allow_custom_messages": true
      }
    },
    "cancel_open_orders_on_exit": false,
    "unfilledtimeout": {
        "entry": 10,
        "exit": 30
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": false,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": false
    },
    "amend_last_stake_amount": false,
    "exchange": {
        "name": "binance",
        "key": "YOUR_EXCHANGE_KEY",
        "secret": "YOUR_EXCHANGE_SECRET",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
      "BTC/USDT",
      "ETH/USDT",
      "AVAX/USDT",
      "DOT/USDT"
    ],
        "pair_blacklist": [
            "BNB/USDT"
        ]
    },
    "pairlists": [
        {
            "method": "StaticPairList"
        }
    ],
    "bot_name": "PolymarketEdgeBot",
    "initial_state": "running",
    "force_entry_enable": false,
    "internals": {
        "process_throttle_secs": 5
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "127.0.0.1",
        "listen_port": 8081,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "freqtrade-secret-key-32-chars-long",
        "CORS_origins": [],
        "username": "freqtrader",
        "password": "YOUR_API_SERVER_PASSWORD"
    },
    "hyperopt_loss": "SharpeHyperOptLoss",
    "spaces": ["buy", "sell", "roi", "stoploss"]
}
